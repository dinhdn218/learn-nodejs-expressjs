<div class='courses-page container'>
  <div class='row'>
    {{#each courses}}
      <div class='col-sm-6 col-lg-4 mb-3'>
        <div class='card h-100 overflow-hidden'>
          <img src={{this.thumbnail}} alt={{this.title}} />
          <div class='card-body d-flex flex-column align-items-start'>
            <h5 class='card-title'>{{this.title}}</h5>
            <p class='card-text'>{{this.description}}</p>
            <div class='d-flex gap-2 mt-auto'>
              <a class='btn btn-primary' href='/courses/{{this.slug}}'>Xem chi
                tiết</a>
              <a class='btn btn-success' href='/courses/edit/{{this._id}}'>Chỉnh
                sửa</a>
              <a
                class='btn btn-danger'
                data-bs-toggle='modal'
                data-bs-target='#delete-modal'
                data-bs-whatever={{this._id}}
              >Xoá</a>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
</div>

<!-- Modal -->
<div
  class='modal fade'
  id='delete-modal'
  tabindex='-1'
  aria-labelledby='delete-course-modal'
  aria-hidden='true'
>
  <div class='modal-dialog modal-dialog-centered'>
    <div class='modal-content'>
      <div class='modal-header'>
        <h5 class='modal-title' id='delete-course-modal'>Xoá khoá học</h5>
        <button
          type='button'
          class='btn-close'
          data-bs-dismiss='modal'
          aria-label='Close'
        ></button>
      </div>
      <div class='modal-body'>
        Bạn có chắc chắn muốn xoá khoá học này?
      </div>
      <div class='modal-footer'>
        <button
          type='button'
          class='btn btn-secondary'
          data-bs-dismiss='modal'
        >Huỷ</button>
        <a type='button' class='btn btn-danger btn-confirm'>Xác nhận</a>
      </div>
    </div>
  </div>
</div>

<form id='form-submit-delete' method='POST'></form>

{{! Script }}
<script src='/js/modalDeleteCourse.js'></script>